#!/usr/bin/env python3
import os
import sys
from pathlib import Path

if os.name == "nt":
    sibling_python = Path(__file__).with_name("python.exe")
    if sibling_python.exists() and Path(sys.executable).resolve() != sibling_python.resolve():
        os.execv(str(sibling_python), [str(sibling_python), "-m", "divapply", *sys.argv[1:]])

from divapply.cli import app

app()
