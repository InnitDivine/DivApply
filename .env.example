# DivApply environment configuration
# Copy to ~/.divapply/.env and fill in your values.

# AI-assisted stages: use one provider.
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_URL=

# Default model. Gemini is the easiest free-tier starting point.
LLM_MODEL=gemini-2.0-flash

# Optional per-stage model overrides.
LLM_MODEL_SCORE=
LLM_MODEL_TAILOR=
LLM_MODEL_COVER=
LLM_MODEL_APPLY=

# Optional bounded LLM request policy. Attempts may be 1-3; delay values are capped at 60s.
DIVAPPLY_LLM_CONNECT_TIMEOUT=10
DIVAPPLY_LLM_READ_TIMEOUT=300
DIVAPPLY_LLM_WRITE_TIMEOUT=30
DIVAPPLY_LLM_POOL_TIMEOUT=10
DIVAPPLY_LLM_MAX_ATTEMPTS=3
DIVAPPLY_LLM_TOTAL_TIMEOUT=600
DIVAPPLY_LLM_RETRY_BASE_DELAY=5
DIVAPPLY_LLM_RETRY_MAX_DELAY=60

# Local apply logs are private and expire automatically after 30 days. Set 0 to retain indefinitely.
DIVAPPLY_LOG_RETENTION_DAYS=30

# Optional browser / automation settings
DIVAPPLY_APPLY_BACKEND=
DIVAPPLY_BROWSER=firefox
CHROME_PATH=
